#!/usr/bin/env python3
"""Render index.html.j2 → index.html via Jinja2.

Edit:
  - index.html.j2     for layout / CSS / structure (plain HTML + Jinja2 tags)
  - PROFILE below     for the page's identity strings (name, URL, DID, …)
  - ICONS below       to add / remove / reorder profile links

Then run:
  just build

SVGs are fetched once from FontAwesome Free, cached in icons/ (committed
to the repo for reproducible builds), and inlined into the template.
Delete icons/ and re-run to refresh from upstream.
"""
from __future__ import annotations

import json
import re
import sys
import urllib.request
from pathlib import Path

try:
    from jinja2 import Environment, FileSystemLoader, StrictUndefined, select_autoescape
except ImportError:
    sys.exit("ERROR: jinja2 required. Install with: pip install jinja2")

# ──────────────────────────────────────────────────────────────────────────
# Single source of truth for the primary domain. The Bluesky handle and
# canonical URL are both derived from this — change here and everything
# else flows through.
DOMAIN = "chadloder.dev"

# Other domains owned by the same identity. Configured to 301-redirect to
# DOMAIN at the registrar (Gandi web forwarding). Surfaced in the JSON-LD
# WebSite block as `alternateName` so search engines and LLM crawlers
# treat them as aliases of the primary site.
ALIAS_DOMAINS = ["chadloder.com", "chadloder.org"]

# Identity / metadata. Drives <title>, <meta>, JSON-LD, h-card,
# .well-known/webfinger (Mastodon), .well-known/host-meta (legacy XRD),
# .well-known/atproto-did (Bluesky HTTPS fallback).
PROFILE: dict = {
    "name":           "Chad Loder",
    "job_title":      "Security researcher & technologist",
    "description":    "Chad Loder — security researcher and technologist.",
    "username":       "chadloder",
    "did":            "did:plc:nywb5oene54cllowkfwouxzz",
    # Mastodon home instance. WebFinger here aliases
    # acct:<username>@<DOMAIN> to the canonical kolektiva account so
    # @chadloder@chadloder.dev resolves the same as @chadloder@kolektiva.social.
    "mastodon_instance": "kolektiva.social",
    "mastodon_profile":  "https://kolektiva.social/@chadloder",
    "mastodon_actor":    "https://kolektiva.social/users/chadloder",
    # Derived — DOMAIN is the source of truth.
    "domain":         DOMAIN,
    "url":            f"https://{DOMAIN}/",
    "atproto_handle": DOMAIN,
    "alias_domains":  ALIAS_DOMAINS,
}

# Profile links. Each tuple: (slug, style, href, link text, platform name, rel)
#   slug:     FA icon slug (e.g. 'bluesky')
#   style:    'brands' | 'solid' | 'regular'
#   href:     URL the link points to
#   text:     visible text shown next to the icon
#   platform: short platform name; combined with text into aria-label
#   rel:      link rel attribute ('me' for identity verification, '' for none)
ICONS: list[tuple[str, str, str, str, str, str]] = [
    ("github",    "brands", "https://github.com/chad-loder",              "chad-loder",                    "GitHub",     "me"),
    ("linkedin",  "brands", "https://www.linkedin.com/in/chadloder/",     "in/chadloder",                  "LinkedIn",   "me"),
    ("bluesky",   "brands", "https://bsky.app/profile/chadloder.dev",     "@chadloder.dev",                "Bluesky",    "me"),
    ("mastodon",  "brands", "https://kolektiva.social/@chadloder",        "@chadloder@kolektiva.social",   "Fediverse",  "me"),
    ("newspaper", "solid",  "https://newsletter.extremism.io",            "extremism.io",                  "Newsletter", ""),
]
# ──────────────────────────────────────────────────────────────────────────

FA_REF = "6.7.2"  # pinned FontAwesome Free release
FA_BASE = f"https://raw.githubusercontent.com/FortAwesome/Font-Awesome/{FA_REF}/svgs"

REPO_ROOT = Path(__file__).resolve().parent.parent
ICONS_DIR = REPO_ROOT / "icons"
TEMPLATE_PATH = REPO_ROOT / "index.html.j2"
OUTPUT_PATH = REPO_ROOT / "index.html"
WELL_KNOWN_DIR = REPO_ROOT / ".well-known"
WEBFINGER_PATH = WELL_KNOWN_DIR / "webfinger"
HOST_META_PATH = WELL_KNOWN_DIR / "host-meta"
ATPROTO_DID_PATH = WELL_KNOWN_DIR / "atproto-did"


def fetch_svg(slug: str, style: str) -> str:
    """Return SVG text. Cache hit: read disk. Cache miss: fetch + persist."""
    cache = ICONS_DIR / f"{style}-{slug}.svg"
    if cache.exists():
        return cache.read_text()
    url = f"{FA_BASE}/{style}/{slug}.svg"
    print(f"  fetching {style}/{slug}", file=sys.stderr)
    with urllib.request.urlopen(url, timeout=10) as resp:
        if resp.status != 200:
            sys.exit(f"ERROR: GET {url} returned {resp.status}")
        text = resp.read().decode("utf-8")
    ICONS_DIR.mkdir(exist_ok=True)
    cache.write_text(text)
    return text


def parse_svg(svg_text: str) -> tuple[str, str]:
    """Return (viewBox value, inner SVG markup) from an SVG document."""
    vb = re.search(r'viewBox="([^"]+)"', svg_text)
    if not vb:
        sys.exit("ERROR: SVG missing viewBox")
    inner = re.search(r"<svg[^>]*>(.*?)</svg>", svg_text, re.DOTALL)
    if not inner:
        sys.exit("ERROR: SVG malformed (no <svg>...</svg>)")
    return vb.group(1), inner.group(1).strip()


def prune_cache(icons_dir: Path, expected: set[str]) -> None:
    if not icons_dir.exists():
        return
    for f in icons_dir.iterdir():
        if f.is_file() and f.suffix == ".svg" and f.name not in expected:
            print(f"  pruning {f.name}", file=sys.stderr)
            f.unlink()


def build_jsonld(profile: dict, icons: list[tuple]) -> str:
    """Schema.org JSON-LD as a JSON string ready for the template.

    Emits a @graph of three linked nodes (Person, WebSite, WebPage) so
    search engines and LLM crawlers can stitch the entity together by
    @id reference. sameAs is reserved for *external* reference profiles;
    own-domain aliases (.com/.org redirects to .dev) live on
    WebSite.alternateName per Google's site-names guidance.
    """
    same_as = [
        href for _, _, href, *_ in icons
        if href.startswith(("http://", "https://"))
    ]
    person_id = profile["url"] + "#person"
    website_id = profile["url"] + "#website"
    webpage_id = profile["url"] + "#webpage"

    person = {
        "@type":       "Person",
        "@id":         person_id,
        "name":        profile["name"],
        "url":         profile["url"],
        "jobTitle":    profile["job_title"],
        "description": profile["description"],
        "identifier": [
            {"@type": "PropertyValue", "propertyID": "did:plc",        "value": profile["did"]},
            {"@type": "PropertyValue", "propertyID": "atproto-handle", "value": profile["atproto_handle"]},
        ],
        "sameAs": same_as,
    }

    website: dict = {
        "@type":     "WebSite",
        "@id":       website_id,
        "url":       profile["url"],
        "name":      profile["domain"],
        "about":     {"@id": person_id},
        "publisher": {"@id": person_id},
    }
    if profile.get("alias_domains"):
        website["alternateName"] = profile["alias_domains"]

    webpage = {
        "@type":    "WebPage",
        "@id":      webpage_id,
        "url":      profile["url"],
        "isPartOf": {"@id": website_id},
        "about":    {"@id": person_id},
    }

    data = {
        "@context": "https://schema.org",
        "@graph":   [person, website, webpage],
    }
    # sort_keys=True gives lexicographic stability across runs — same
    # input → same bytes regardless of how the dicts were constructed.
    # This keeps generated index.html cache-friendly: regenerating with
    # unchanged data produces a byte-identical output.
    return json.dumps(data, indent=2, ensure_ascii=False, sort_keys=True)


def build_webfinger(profile: dict) -> str:
    """Mastodon-compatible WebFinger JRD using the redirect pattern.

    Aliases @<username>@<DOMAIN> to the canonical Mastodon account
    (@<username>@<mastodon_instance>) so fediverse clients searching
    for @chadloder@chadloder.dev resolve to the same account as
    @chadloder@kolektiva.social. The kolektiva account stays canonical;
    this is a discoverable alias.

    Subject is the CANONICAL handle, not the vanity. This triggers the
    "WebFinger redirect" code path in Mastodon's ResolveAccountService:
    Mastodon sees the subject points to a different domain than the
    one queried, then re-queries that domain to confirm. As long as
    the canonical instance returns a matching subject (which it always
    does for its own users), the alias resolves successfully — no
    server-side WEB_DOMAIN config required on the canonical instance.

    Note on GitHub Pages: this file is served as
    application/octet-stream (no extension; Pages can't set custom
    Content-Type). Mastodon's Webfinger class doesn't validate
    Content-Type — it just JSON.parses the body — so this works in
    practice despite mastodon/mastodon#11191 calling for relaxation.
    """
    canonical_user = f"{profile['username']}@{profile['mastodon_instance']}"
    instance = profile["mastodon_instance"]
    data = {
        "subject": f"acct:{canonical_user}",
        "aliases": [
            profile["mastodon_profile"],
            profile["mastodon_actor"],
        ],
        "links": [
            {
                "rel":  "http://webfinger.net/rel/profile-page",
                "type": "text/html",
                "href": profile["mastodon_profile"],
            },
            {
                "rel":  "self",
                "type": "application/activity+json",
                "href": profile["mastodon_actor"],
            },
            {
                "rel":      "http://ostatus.org/schema/1.0/subscribe",
                "template": f"https://{instance}/authorize_interaction?uri={{uri}}",
            },
        ],
    }
    return json.dumps(data, indent=2, ensure_ascii=False, sort_keys=True)


def build_host_meta(profile: dict) -> str:
    """Legacy XRD pointing at the WebFinger endpoint.

    Modern Mastodon queries /.well-known/webfinger directly without
    consulting host-meta, but older / non-Mastodon clients still
    discover the endpoint this way. Cheap to include.
    """
    return (
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<XRD xmlns="http://docs.oasis-open.org/ns/xri/xrd-1.0">\n'
        f'  <Link rel="lrdd" template="https://{profile["domain"]}/.well-known/webfinger?resource={{uri}}"/>\n'
        '</XRD>\n'
    )


def main() -> None:
    if not TEMPLATE_PATH.exists():
        sys.exit(f"ERROR: {TEMPLATE_PATH} not found")

    print(f"Building from {TEMPLATE_PATH.name} ({len(ICONS)} icons, FA {FA_REF})...", file=sys.stderr)

    icons_data: list[dict] = []
    for slug, style, href, text, platform, rel in ICONS:
        svg_text = fetch_svg(slug, style)
        viewbox, svg_inner = parse_svg(svg_text)
        icons_data.append({
            "slug": slug, "style": style, "href": href, "text": text,
            "platform": platform, "rel": rel,
            "viewbox": viewbox, "svg_inner": svg_inner,
        })

    env = Environment(
        loader=FileSystemLoader(REPO_ROOT),
        autoescape=select_autoescape(["html", "j2"]),
        undefined=StrictUndefined,
        keep_trailing_newline=True,
    )
    template = env.get_template(TEMPLATE_PATH.name)
    rendered = template.render(
        profile=PROFILE,
        icons=icons_data,
        jsonld=build_jsonld(PROFILE, ICONS),
    )
    OUTPUT_PATH.write_text(rendered)
    print(f"Wrote {OUTPUT_PATH.name} ({OUTPUT_PATH.stat().st_size} bytes)", file=sys.stderr)

    WELL_KNOWN_DIR.mkdir(exist_ok=True)
    WEBFINGER_PATH.write_text(build_webfinger(PROFILE))
    HOST_META_PATH.write_text(build_host_meta(PROFILE))
    ATPROTO_DID_PATH.write_text(PROFILE["did"] + "\n")
    for p in (WEBFINGER_PATH, HOST_META_PATH, ATPROTO_DID_PATH):
        print(f"Wrote {p.relative_to(REPO_ROOT)} ({p.stat().st_size} bytes)", file=sys.stderr)

    expected = {f"{i['style']}-{i['slug']}.svg" for i in icons_data}
    prune_cache(ICONS_DIR, expected)


if __name__ == "__main__":
    main()
